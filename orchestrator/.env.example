# reprovision config — put REFERENCES here, not secrets.
#
# Secrets are resolved at run time from 1Password (op:// refs) or GCP Secret Manager
# (a secret id), using your own `gcloud auth login` / `op signin`. Copy to `.env`.
# See the README "Config & secrets" section.

# GCP project for Secret Manager lookups
REPROVISION_GCP_PROJECT=relops-bootstrap

# SimpleMDM API key — defaults to Secret Manager id "simplemdm-api-token" (usually leave as-is)
# REPROVISION_SIMPLEMDM_API_KEY_REF=simplemdm-api-token

# TC quarantine-worker creds (only needed for quarantine/drain/unquarantine steps).
# Point at a Secret Manager id or an op:// ref:
# REPROVISION_TC_CLIENT_ID_REF=<secret-manager-id or op://Vault/Item/field>
# REPROVISION_TC_ACCESS_TOKEN_REF=<secret-manager-id or op://Vault/Item/field>

# Fixed DEP admin password for the mint login — prefer a 1Password ref:
# REPROVISION_SSH_ADMIN_PASSWORD_REF=op://RelOps Vault/m4 admin/password

# Direct-value overrides (CI / debugging only — avoid in normal use; keeps secrets out of the shell):
# REPROVISION_SIMPLEMDM_API_KEY=...
# REPROVISION_TC_CLIENT_ID=project/releng/quarantine-worker
# REPROVISION_TC_ACCESS_TOKEN=...
# REPROVISION_SSH_ADMIN_PASSWORD=...
